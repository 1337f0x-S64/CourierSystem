<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.courier.controllers.TrackingViewsController"
            prefHeight="400.0" prefWidth="600.0"
            style="-fx-background-color: #9CD5FF;">

    <Label text="View Track Order" style="-fx-font-weight: bold; -fx-font-family: 'Times New Roman'; -fx-font-size: 14px;"/>

    <VBox alignment="CENTER" spacing="15.0" AnchorPane.topAnchor="50.0" AnchorPane.leftAnchor="50.0"
          AnchorPane.rightAnchor="50.0" AnchorPane.bottomAnchor="50.0">

        <Label text="Track Your Package" style="-fx-font-size: 18px; -fx-text-fill: black; -fx-font-weight: bold; fx-font-family: 'Times New Roman';" />

        <HBox spacing="10">
            <TextField fx:id="trackingField" promptText="Enter Tracking ID" HBox.hgrow="ALWAYS" style="-fx-font-family: 'Times New Roman';fx-font-size: 14px;" prefWidth="200"/>

            <Button text="Track Package" onAction="#trackPackage" style="-fx-background-color: #0d47a1; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-family: 'Times New Roman'; -fx-font-size: 14px;" prefWidth="200"/>
        </HBox>
        <TableView fx:id="packageTable" prefHeight="200" prefWidth="550">
            <columns>
                <TableColumn fx:id="idColumn" text="Tracking ID" prefWidth="100"  style="-fx-font-weight: bold;-fx-text-fill: black; -fx-font-family: 'Times New Roman'; -fx-font-size: 14px;"/>

                <TableColumn fx:id="descriptionColumn" text="Description" prefWidth="100"  style="-fx-font-weight: bold;-fx-text-fill: black; -fx-font-family: 'Times New Roman'; -fx-font-size: 14px;"/>

                <TableColumn fx:id="startLocationColumn" text="Start Location" prefWidth="100"  style="-fx-font-weight: bold;-fx-text-fill: black; -fx-font-family: 'Times New Roman'; -fx-font-size: 14px;"/>

                <TableColumn fx:id="endLocationColumn" text="End Location" prefWidth="100" style="-fx-font-weight: bold;-fx-text-fill: black; -fx-font-family: 'Times New Roman'; -fx-font-size: 14px;"/>

                <TableColumn fx:id="statusColumn" text="Status" prefWidth="100"  style="-fx-font-weight: bold;-fx-text-fill: black; -fx-font-family: 'Times New Roman'; -fx-font-size: 14px;"/>

                <TableColumn fx:id="deliveryDateColumn" text="Delivery Date" prefWidth="140"  style="-fx-font-weight: bold;-fx-text-fill: black; -fx-font-family: 'Times New Roman'; -fx-font-size: 14px;"/>
            </columns>
        </TableView>

    </VBox>
</AnchorPane>
